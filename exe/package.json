{
  "name": "electron-win",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "icon": "assets/icon.ico",
    "appId": "com.vlinder.pos3",
    "productName": "Pos3",
    "directories": {
      "output": "dist2"
    },
    "files": [
      "**/*"
    ],
    "win": { 
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    } 
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "dotenv": "^17.2.1"
  }
}
